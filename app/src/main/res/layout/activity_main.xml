<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF1F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="190dp"
            android:background="#F72555"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="38dp"
            android:paddingEnd="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌶️ SMARTCHILI"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Monitoring and Controlling System"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtOnline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_online"
                android:paddingStart="18dp"
                android:paddingTop="9dp"
                android:paddingEnd="18dp"
                android:paddingBottom="9dp"
                android:text="● SYSTEM ON"
                android:textColor="#F72555"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- CONTENT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="│ MONITORING"
                android:textColor="#F72555"
                android:textSize="17sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌡️"
                        android:textSize="32sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SUHU"
                        android:textColor="#F72555"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtSuhu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="47.2 °C"
                        android:textColor="#E60023"
                        android:textSize="29sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtTargetMini"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Target: 50 °C"
                        android:textColor="#555555"
                        android:textSize="13sp" />
                </LinearLayout>

                <Space
                    android:layout_width="12dp"
                    android:layout_height="1dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💧"
                        android:textSize="32sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KELEMBABAN"
                        android:textColor="#1E88E5"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtKelembaban"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="32.6 %"
                        android:textColor="#1E88E5"
                        android:textSize="29sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status: Normal"
                        android:textColor="#555555"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="│ STATUS PERANGKAT"
                android:textColor="#F72555"
                android:textSize="17sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtHeater"
                    android:layout_width="0dp"
                    android:layout_height="145dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:gravity="center"
                    android:text="🔥\nHEATER\nON\nMode: Otomatis"
                    android:textColor="#E60023"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="12dp"
                    android:layout_height="1dp" />

                <TextView
                    android:id="@+id/txtFan"
                    android:layout_width="0dp"
                    android:layout_height="145dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card"
                    android:gravity="center"
                    android:text="🌬️\nFAN\nON\nMode: Otomatis"
                    android:textColor="#E60023"
                    android:textSize="17sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="│ KONTROL SISTEM"
                android:textColor="#F72555"
                android:textSize="17sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnSystem"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#F72555"
                android:text="⏻  SYSTEM ON"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="│ PENGATURAN SUHU TARGET"
                android:textColor="#F72555"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtTarget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Target Suhu: 50 °C"
                android:textColor="#E60023"
                android:textSize="23sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/seekTarget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="60"
                android:progress="30" />

            <TextView
                android:id="@+id/txtInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:text="⏱️  Durasi Pengeringan: 02:35:47\n📅  Tanggal: 25 Mei 2025"
                android:textColor="#333333"
                android:textSize="16sp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>